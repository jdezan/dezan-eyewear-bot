# ═══════════════════════════════════════════════════════════════
#   Dezan Eyewear — Bot WhatsApp
#   Copie este arquivo para .env e preencha os valores reais
# ═══════════════════════════════════════════════════════════════

# ── LLM (IA) ──────────────────────────────────────────────────
# Use Groq (GRATUITO): https://console.groq.com
LLM_PROVIDER=groq
LLM_MODEL=llama-3.3-70b-versatile
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx

# Ou OpenAI (pago):
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o-mini
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx

# ── Embeddings ────────────────────────────────────────────────
# HuggingFace roda localmente, zero custo (padrao)
EMBEDDING_PROVIDER=huggingface
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# ── Evolution API ─────────────────────────────────────────────
EVOLUTION_API_URL=https://evolution-api-evolution-api.rs7gvp.easypanel.host
EVOLUTION_API_KEY=SEU_API_KEY_DO_EVOLUTION_AQUI
EVOLUTION_INSTANCE=dezan-eyeware

# ── Links da loja ─────────────────────────────────────────────
SITE_URL=https://dezaneyewear.com.br
ML_URL=https://lista.mercadolivre.com.br/_CustId_6112331

# ── FAQ Google Sheets ─────────────────────────────────────────
# Planilha publicada como CSV
# Planilha > Arquivo > Publicar na Web > Aba > CSV > Copiar URL
GOOGLE_SHEETS_FAQ_URL=https://docs.google.com/spreadsheets/d/SEU_ID/export?format=csv&gid=0

# ── Admin ─────────────────────────────────────────────────────
ADMIN_KEY=troque-para-uma-senha-forte

# ── Telegram (opcional) ───────────────────────────────────────
# TELEGRAM_BOT_TOKEN=token-do-botfather

# ── Geral ─────────────────────────────────────────────────────
DATA_DIR=./data
API_PORT=8000
